# default.path-guard — shipped defaults for the path-guard hook.
#
# Two sections:
#   [secret]    — block Read AND Write (file is sensitive; agent should not
#                 see its contents nor modify it)
#   [protected] — block Write only (file is readable for inspection but
#                 should not be modified by the agent)
#
# Pattern syntax (glob, gitignore-flavoured):
#   *             matches any chars within a path segment (no /)
#   **            matches any number of path segments
#   ?             matches one char (no /)
#   [abc]         char class
#   ~             leading tilde expands to $HOME
#   leading /     anchors to filesystem root
#   no leading /  matches the basename anywhere in the path
#   trailing /**  also matches the directory itself (not just its contents)
#
# No `!` negation. To remove a default rule, comment out the line in this
# file or override at the user level (~/.claude/.path-guard) or project
# level ($CLAUDE_PROJECT_DIR/.path-guard) — all three files concatenate.
#
# Comments begin with # and run to end of line.

[secret]

# === SSH keys, config, known_hosts ===
~/.ssh/**
/root/.ssh/**
/home/*/.ssh/**

# === Cloud / service credentials ===
~/.aws/**
~/.gnupg/**
~/.kube/**
~/.config/gh/**
~/.netrc
~/.docker/config.json

# === System secret files ===
/etc/shadow
/etc/gshadow
/etc/sudoers
/etc/sudoers.d/**
/proc/*/environ

# === SSH/TLS private keys by basename (anywhere on disk) ===
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519

# === Cert / key / keystore extensions (anywhere on disk) ===
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx
*.jks
*.keystore
*.keytab

# === GPG / OpenVPN / KeePass / age ===
*.asc
*.gpg
*.ovpn
*.kdbx
*.age

# === Environment-variable files (commonly contain secrets) ===
.env
.env.*

# === Frequently-used secret file names ===
secrets.yaml
secrets.yml
credentials
credentials.json
service-account*.json

[protected]

# === Claude Code configuration ===
.claude/settings.json
.claude/settings.local.json
~/.claude/settings.json
~/.claude/settings.local.json

# === CLAUDE.md (project + user) ===
CLAUDE.md
~/.claude/CLAUDE.md

# === Hook scripts — the actual guard executables, not tests or docs ===
.claude/hooks/**/hook.sh
.claude/hooks/**/compact.sh

# === Hook adapters — daemon-route shims proxying every tool call ===
# Functionally the same blast radius as .claude/hooks/**/hook.sh: an
# attacker editing _lib.sh or a per-hook adapter (`scratch-allow.sh`,
# `path-guard.sh`, …) can intercept every Pre/Post tool invocation the
# project routes through the hook-daemon. Protect the whole subtree so
# new adapters added later are covered without per-file updates.
.claude/hook-adapters/**

# === Git internals — config, refs, packed objects, hooks ===
# .git is the directory at the repo root for ordinary clones and the file
# pointing into .git/modules/<sub>/ for submodules; the real submodule gitdir
# lives at the superproject's .git/modules/<sub>/. Matching .git as a path
# segment catches every form. Reads are still allowed (this section is
# [protected], not [secret]) so `git log` / `git rev-parse` style inspection
# of internals still works.
.git
.git/**

# === claude-tools realpaths (symlinked-submodule defense in depth) ===
# .claude/hooks/<name>/{hook,compact}.sh is typically a symlink into the
# claude-tools submodule's hooks/<name>/. path-guard normalises through
# symlinks via realpath, so the .claude/hooks/**/{hook,compact}.sh patterns
# above no longer match the resolved path. These rules catch the resolved
# form (assuming the submodule lives at a path containing the directory
# name "claude-tools"). install.sh also writes a project-local .path-guard
# with the exact submodule-relative path so this works when claude-tools is
# vendored at a non-canonical location.
claude-tools/hooks/**/hook.sh
claude-tools/hooks/**/compact.sh

# === claude-tools scripts/ — git-hook sources, installer, mirror script ===
# Modifying any of these is arbitrary-code-on-next-push or
# arbitrary-code-on-next-install. claude-tools/scripts/git-hooks/<hook> is
# the symlink target of <gitdir>/hooks/<hook>; the .git/** rule above
# blocks the symlink path, this rule blocks the realpath.
claude-tools/scripts/**
